{
    "name": "zsoltgombocz/steam-workshop-php",
    "description": "A lightweight PHP client for fetching Steam Workshop item and collection metadata.",
    "keywords": [
        "steam_workshop",
        "php"
    ],
    "homepage": "https://github.com/zsoltgombocz/steam-workshop-php",
    "license": "LGPL-2.1",
    "type": "library",
    "authors": [
        {
            "name": "Zsolt Gömböcz",
            "email": "zsolt.gombocz00@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.4",
        "spatie/ray": "^1.28"
    },
    "autoload": {
        "psr-4": {
            "SteamWorkshop\\Src\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SteamWorkshop\\Tests\\": "tests"
        }
    },
    "scripts": {},
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
